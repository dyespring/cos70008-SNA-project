# Copy to `.env` and source it before running `docker compose up` or the pipeline.
#
#   cp .env.example .env
#   set -a && source .env && set +a
#
# .env is gitignored.

# ── Neo4j (local Docker) ───────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-local
NEO4J_DATABASE=neo4j

# ── LLM / RAG (optional) ───────────────────────────────────────────
# LLM_PROVIDER=echo                # echo | openai | dashscope | huggingface_api | huggingface_local
# LLM_MODEL=gpt-4o-mini            # provider-specific model id
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=512

# OpenAI
# OPENAI_API_KEY=sk-...

# Aliyun DashScope (Qwen) — OpenAI-compatible
# LLM_PROVIDER=dashscope
# LLM_MODEL=qwen-turbo             # qwen-turbo | qwen-plus | qwen-max | qwen2.5-72b-instruct
# DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Hugging Face
# HUGGINGFACE_API_TOKEN=hf_...
